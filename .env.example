# Database configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/oxelia51?sslmode=disable

# Server configuration
CS2LAB_PORT=8001
GIN_MODE=release
CORS_ALLOWED_ORIGINS=http://localhost:5173
DB_MAX_CONNS=5

# Gateway mode (set to true when running behind Oxelia51 gateway)
OXELIA_GATEWAY_MODE=false

# Static files directory (for lineup images)
CS2LAB_STATIC_DIR=./data
